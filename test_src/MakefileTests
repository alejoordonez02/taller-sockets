#FLAGS
CXX = g++
CXXFLAGS = -Wall -Wextra -std=c++17 -g -D_GNU_SOURCE -D _POSIX_C_SOURCE=200809L
INCLUDES = -I../common_src

#SOURCE FILES
SRC = ../common_src/common_socket.cpp \
	../common_src/common_liberror.cpp \
	../common_src/common_resolver.cpp \
	../common_src/common_resolvererror.cpp \
	../common_src/common_protocol.cpp \
	../common_src/common_binary_protocol.cpp \
	../common_src/common_text_protocol.cpp \
	../common_src/common_serializer.cpp \
	../common_src/common_binary_serializer.cpp \
	../common_src/common_text_serializer.cpp \
	../common_src/common_command.cpp \
	../common_src/common_output.cpp \
	../common_src/common_tokenizer.cpp

#OBJECT FILES
OBJ = $(SRC:.cpp=.o)

#TEST FILES
TEST_SRC = test_protocol.cpp \
	test_serializer.cpp \
	test_binary_serializer.cpp \
	test_command.cpp \
	test_output.cpp \
	test_text_serializer.cpp

#TEST OBJECT FILES
TEST_OBJ = $(TEST_SRC:.cpp=.o)

#TESTS
TESTS = test_protocol \
	test_serializer \
	test_binary_serializer \
	test_command \
	test_output \
	test_text_serializer

all: $(TESTS)

clean:
	rm -f $(TESTS) *.o

test_protocol: test_protocol.o $(OBJ)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $^

test_serializer: test_serializer.o $(OBJ)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $^

test_binary_serializer: test_binary_serializer.o $(OBJ)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $^

test_command: test_command.o $(OBJ)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $^

test_output: test_output.o $(OBJ)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $^

test_text_serializer: test_text_serializer.o $(OBJ)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $^

%.o: %.cpp
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c $< -o $@

#RUN
run_protocol: test_protocol
	./test_protocol

run_serializer: test_serializer
	./test_serializer

run_binary_serializer: test_binary_serializer
	./test_binary_serializer

run_command: test_command
	./test_command

run_output: test_output
	./test_output

run_test_serializer: test_text_serializer
	./test_text_serializer

run_all: $(TESTS)
	@echo "Running all tests..."
	@for test in $(TESTS);
do echo "--- Running $$test ---";
./ $$test;
done

#PHONY
        .PHONY:
        all clean run_protocol run_serializer run_binary_serializer run_command run_output
                run_text_serializer run_all
