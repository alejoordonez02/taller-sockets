CXX = g++
CXXFLAGS = -Wall -Wextra -std=c++17 -g
INCLUDES = -I../common_src

PROTOCOL_SRC = ../common_src/common_protocol.cpp \
	../common_src/common_binary_protocol.cpp \
	../common_src/common_text_protocol.cpp \

COMMAND_SRC = ../common_src/common_command.cpp

MODEL_SRC = ../server_src/server_player.cpp \
	../server_src/server_weapon.cpp

COMMAND_PROCESSOR_SRC = ../server_src/server_command_processor.cpp

OUTPUT_SRC = ../common_src/common_output.cpp

TESTS = test_command test_protocol test_binary_protocol test_player \
	test_weapon test_command_processor test_output

all: $(TESTS)

clean:
	rm -f $(TESTS) *.o

test_command: test_command.cpp $(COMMAND_SRC)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $< $(COMMAND_SRC)

test_protocol: test_protocol.cpp $(PROTOCOL_SRC) $(COMMAND_SRC)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $< $(PROTOCOL_SRC) $(COMMAND_SRC) 

test_binary_protocol: test_binary_protocol.cpp $(PROTOCOL_SRC) $(COMMAND_SRC)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $< $(PROTOCOL_SRC) $(COMMAND_SRC)

test_player: test_player.cpp $(MODEL_SRC)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $< $(MODEL_SRC)

test_weapon: test_weapon.cpp $(MODEL_SRC)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $< $(MODEL_SRC)

test_command_processor: test_command_processor.cpp \
	$(COMMAND_PROCESSOR_SRC) $(COMMAND_SRC) $(MODEL_SRC)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $< \
	$(COMMAND_PROCESSOR_SRC) $(COMMAND_SRC) $(MODEL_SRC)

test_output: test_output.cpp \
	$(OUTPUT_SRC) $(COMMAND_SRC)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ $< \
	$(OUTPUT_SRC) $(COMMAND_SRC)

run_command: test_command
	./test_command

run_protocol: test_protocol
	./test_protocol

run_binary: test_binary_protocol
	./test_binary_protocol

run_player: test_player
	./test_player

run_weapon: test_weapon
	./test_weapon

run_command_processor: test_command_processor
	./test_command_processor

run_output: test_output
	./test_output

run_all: $(TESTS)
	@echo "Running all tests..."
	@for test in $(TESTS); do \
		echo "--- Running $$test ---"; \
		./$$test; \
	done

test_command.o: test_command.cpp ../common_src/common_command.h
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c -o $@ $<

test_protocol.o: test_protocol.cpp ../common_src/common_protocol.h \
	../common_src/common_binary_protocol.h \
	../common_src/common_text_protocol.h \
	../common_src/common_command.h
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c -o $@ $<

test_binary_protocol.o: test_binary_protocol.cpp ../common_src/common_protocol.h \
	../common_src/common_binary_protocol.h \
	../common_src/common_command.h
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c -o $@ $<

test_player.o: test_player.cpp ../server_src/server_player.h \
	../server_src/server_weapon.h
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c -o $@ $<

test_command_processor.o: test_command_processor.cpp \
	../server_src/server_command_processor.h \
	../common_src/common_command.h \
	../server_src/server_player.h \
	../server_src/server_weapon.h

test_output.o: test_output.src \
	../common_src/common_output.h \
	../common_src/common_command.h

.PHONY: all clean run_command run_protocol run_binary run_player run_weapon run_command_processor run_all
