# FLAGS
CXX = g++
CXXFLAGS = -Wall -Wextra -std=c++17 -g -D_GNU_SOURCE -D _POSIX_C_SOURCE=200809L
INCLUDES = -I../common_src

# SOURCES
SOCKET_SRC = ../common_src/common_socket.cpp \
	../common_src/common_liberror.cpp \
	../common_src/common_resolver.cpp \
	../common_src/common_resolvererror.cpp

PROTOCOL_SRC = ../common_src/common_protocol.cpp

SERIALIZER_SRC = ../common_src/common_serializer.cpp

BINARY_SERIALIZER_SRC = ../common_src/common_binary_serializer.cpp

TEXT_SERIALIZER_SRC = ../common_src/common_text_serializer.cpp

COMMAND_SRC = ../common_src/common_command.cpp

OUTPUT_SRC = ../common_src/common_output.cpp

TOKENIZER_SRC = ../common_src/common_tokenizer.cpp


SOCKET = $(SOCKET_SRC:.cpp=.o)
PROTOCOL = $(PROTOCOL_SRC:.cpp=.o)
SERIALIZER = $(SERIALIZER_SRC:.cpp=.o)
BINARY_SERIALIZER = $(BINARY_SERIALIZER_SRC:.cpp=.o)
TEXT_SERIALIZER = $(TEXT_SERIALIZER_SRC:.cpp=.o)
COMMAND = $(COMMAND_SRC:.cpp=.o)
OUTPUT = $(OUTPUT_SRC:.cpp=.o)
TOKENIZER = $(TOKENIZER_SRC:.cpp=.o)

# TESTS
TESTS = test_protocol test_serializer test_command

all: $(TESTS)

clean:
	rm -f $(TESTS) *.o

test_protocol: test_protocol.o $(PROTOCOL) $(SOCKET) $(SERIALIZER) $(BINARY_SERIALIZER) $(TEXT_SERIALIZER) $(COMMAND) $(OUTPUT) $(TOKENIZER)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ test_protocol.o $(PROTOCOL) $(SOCKET) $(SERIALIZER) $(BINARY_SERIALIZER) $(TEXT_SERIALIZER) $(COMMAND) $(OUTPUT) $(TOKENIZER)

test_serializer: test_serializer.o $(SERIALIZER) $(BINARY_SERIALIZER) $(TEXT_SERIALIZER)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ test_serializer.o $(SERIALIZER) $(BINARY_SERIALIZER) $(TEXT_SERIALIZER)

test_command: test_command.o $(COMMAND) $(TOKENIZER)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ test_command.o $(COMMAND) $(TOKENIZER)

%.o: %.cpp
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c $< -o $@

# RUN
run_protocol: test_protocol
	./test_protocol

run_serializer: test_serializer
	./test_serializer

run_all: $(TESTS)
	@echo "Running all tests..."
	@for test in $(TESTS); do \
		echo "--- Running $$test ---"; \
		./$$test; \
	done

# PHONY
.PHONY: all clean run_protocol run_serializer run_all
