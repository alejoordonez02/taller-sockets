# FLAGS
CXX = g++
CXXFLAGS = -Wall -Wextra -std=c++17 -g -D_GNU_SOURCE -D _POSIX_C_SOURCE=200809L
INCLUDES = -I../common_src

# SOURCES
PROTOCOL_SRC = ../common_src/common_protocol.cpp \
	../common_src/common_binary_protocol.cpp \
	../common_src/common_text_protocol.cpp \
	../common_src/common_output.cpp \
	../common_src/common_command.cpp

SERIALIZER_SRC = ../common_src/common_serializer.cpp \
	../common_src/common_binary_serializer.cpp \
	../common_src/common_text_serializer.cpp

SOCKET_SRC = ../common_src/common_socket.cpp \
	../common_src/common_liberror.cpp \
	../common_src/common_resolver.cpp \
	../common_src/common_resolvererror.cpp

PROTOCOL = $(PROTOCOL_SRC:.cpp=.o)
SOCKET = $(SOCKET_SRC:.cpp=.o)
SERIALIZER = $(SERIALIZER_SRC:.cpp=.o)

# TESTS
TESTS = test_protocol test_serializer

all: $(TESTS)

clean:
	rm -f $(TESTS) *.o

test_protocol: test_protocol.o $(PROTOCOL) $(SOCKET) $(SERIALIZER)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ test_protocol.o $(PROTOCOL) $(SOCKET) $(SERIALIZER)

test_serializer: test_serializer.o $(SERIALIZER)
	$(CXX) $(CXXFLAGS) $(INCLUDES) -o $@ test_serializer.o $(SERIALIZER)

%.o: %.cpp
	$(CXX) $(CXXFLAGS) $(INCLUDES) -c $< -o $@

# RUN
run_protocol: test_protocol
	./test_protocol

run_serializer: test_serializer
	./test_serializer

run_all: $(TESTS)
	@echo "Running all tests..."
	@for test in $(TESTS); do \
		echo "--- Running $$test ---"; \
		./$$test; \
	done

# PHONY
.PHONY: all clean run_protocol run_serializer run_all
